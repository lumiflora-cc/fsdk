{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true
  },
  "exclude": [
    "node_modules",
    "packages/templates/**/node_modules",
    "packages/templates/base/src",
    "packages/templates/full/src",
    "packages/templates/base/vite.config.ts",
    "packages/templates/full/vite.config.ts"
  ]
}
