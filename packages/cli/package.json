{
  "name": "@lumiflora/fsdk",
  "version": "0.2.1",
  "type": "module",
  "description": "Vue 3 前端项目脚手架 CLI 工具，快速创建包含最佳技术栈的项目骨架。",
  "main": "./dist/index.js",
  "bin": {
    "fsdk": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lumiflora-cc/fsdk"
  },
  "homepage": "https://github.com/lumiflora-cc/fsdk#readme",
  "bugs": {
    "url": "https://github.com/lumiflora-cc/fsdk/issues"
  },
  "files": [
    "dist",
    "scripts/postinstall.js",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && node scripts/fix-bin.js",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "ejs": "^3.1.9",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "json5": "^2.2.3",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.6.0"
  }
}
